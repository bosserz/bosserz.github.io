  <!-- LEARNING FLOW (STEP-BY-STEP) -->
  <section class="section bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-animate>
        <h2 class="serif-heading text-4xl text-brand-navy mb-4">วิธีเรียนของ Intsight (Step-by-step)</h2>
        <p class="text-slate-500 max-w-3xl mx-auto">
          เพื่อให้เหมาะกับ Private และความแตกต่างของผู้เรียน เราใช้กระบวนการที่ชัดเจนและวัดผลได้
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8" data-animate>
        <div class="surface p-8 card-shadow hover-lift">
          <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-3">Step 1</p>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Diagnostic & Goal Setting</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            วัดระดับพื้นฐาน + กำหนดเป้าหมาย (สอบเมื่อไร/ต้องการคะแนนเท่าไร/ยื่นที่ไหน) เพื่อเลือกแพ็กเกจและรูปแบบการเรียนให้เหมาะจริง
          </p>
        </div>

        <div class="surface p-8 card-shadow hover-lift">
          <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-3">Step 2</p>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Personalized Study Plan</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            วางแผนรายสัปดาห์ แบ่งสัดส่วนวิชาตามจุดอ่อน พร้อมกำหนด milestone และการบ้านที่จำเป็น
          </p>
        </div>

        <div class="surface p-8 card-shadow hover-lift">
          <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-3">Step 3</p>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Practice + Error Log</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            ทำโจทย์เข้มข้น พร้อมบันทึกข้อผิดพลาด (concept / careless / time / language) แล้วแก้ซ้ำแบบ targeted
          </p>
        </div>

        <div class="surface p-8 card-shadow hover-lift">
          <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-3">Step 4</p>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Readiness Check</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            ตรวจความพร้อมก่อนสอบ: timed set, กลยุทธ์ทำข้อ, และแผนเก็บแต้มช่วงท้าย เพื่อมั่นใจในวันสอบจริง
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
