<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GED Program | Private / Group | Intsight Education</title>

  <!-- Course Metadata (for homepage integration) -->
  <script type="application/json" id="course-metadata">
  {
    "id": "ged",
    "type": "private",
    "tag": "High School Equivalency",
    "sub": "GED",
    "title": "GED Complete Program",
    "desc": "เตรียมสอบ GED ครบทุกวิชา พร้อมแผนการเรียนเฉพาะบุคคล",
    "hours": "60+ Hours",
    "start": "Flexible Schedule",
    "badge": "Private Available",
    "img": "https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?auto=format&fit=crop&q=80&w=1200",
    "url": "courses/ged.html"
  }
  </script>

  <!-- Tailwind (layout utilities) -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

  <!-- Alpine -->
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

  <!-- Shared Global CSS (your reusable file) -->
  <link rel="stylesheet" href="../assets/css/intsight.css">
</head>

<body class="bg-white text-slate-800" x-data="{ mobile:false, track:'private', plan:'60' }">

  <nav class="fixed inset-x-0 top-0 z-50 glass">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="h-20 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="https://intsightedu.com/wp-content/uploads/2025/10/intsight-logo-web.png" alt="Intsight Education" class="h-10 w-auto" />
        </div>

        <div class="hidden md:flex items-center gap-8">
          <a href="about.html" class="text-sm font-semibold text-slate-700 hover:text-[color:var(--navy)] transition">About</a>
          <a href="#expertise" class="text-sm font-semibold text-slate-700 hover:text-[color:var(--navy)] transition">Services</a>
          <a href="courses.html" class="text-sm font-semibold text-slate-700 hover:text-[color:var(--navy)] transition">Courses</a>
          <a href="#blog" class="text-sm font-semibold text-slate-700 hover:text-[color:var(--navy)] transition">Blogs</a>
          <a href="#team" class="text-sm font-semibold text-slate-700 hover:text-[color:var(--navy)] transition">Team</a>

          <a href="#contact" class="btn-primary px-6 py-3 text-sm font-bold">
            สมัครเรียน
          </a>
        </div>

        <button class="md:hidden p-2" @click="mobileMenu = !mobileMenu" aria-label="Open Menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[color:var(--navy)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Drawer -->
    <div x-show="mobileMenu" x-transition class="md:hidden border-t border-slate-200 bg-white">
      <div class="max-w-7xl mx-auto px-4 py-5 space-y-3">
        <a href="#about" @click="mobileMenu=false" class="block py-2 font-semibold text-slate-700">About</a>
        <a href="#expertise" @click="mobileMenu=false" class="block py-2 font-semibold text-slate-700">Services</a>
        <a href="courses.html" @click="mobileMenu=false" class="block py-2 font-semibold text-slate-700">Courses</a>
        <a href="#blog" @click="mobileMenu=false" class="block py-2 font-semibold text-slate-700">Blogs</a>
        <a href="#team" @click="mobileMenu=false" class="block py-2 font-semibold text-slate-700">Team</a>

        <a href="#contact" @click="mobileMenu=false" class="btn-primary inline-flex items-center justify-center w-full px-6 py-3 font-bold">
          สมัครเรียน
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <header class="pt-32 lg:pt-40 pb-14 bg-soft bg-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-10 items-start">

        <!-- LEFT: Hero content -->
        <div class="lg:col-span-7" data-animate>
          <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="badge badge-blue">High School Equivalency</span>
            <span class="badge badge-soft">Private / Group</span>
            <!-- <span class="badge badge-open">Open</span> -->
          </div>

          <h1 class="serif-heading text-4xl lg:text-6xl text-brand-navy leading-[1.12] mb-6">
            GED
            <span class="block italic text-slate-400 font-light">จะเรียนเดี่ยวหรือกลุ่มก็เลือกได้</span>
          </h1>

          <p class="text-lg lg:text-xl text-slate-600 leading-relaxed max-w-2xl">
            คอร์สเตรียมสอบ GED ของ Intsight ออกแบบเพื่อ “สอบผ่านจริง” ด้วยการวัดระดับก่อนเริ่ม
            วางแผนการเรียนตามพื้นฐาน และฝึกทำข้อสอบอย่างเป็นระบบ พร้อมกลยุทธ์ทำคะแนน
            ไม่ว่าคุณจะต้องการความยืดหยุ่นแบบตัวต่อตัว หรือต้องการเรียนเป็นกลุ่ม ก็เลือกได้ตามความต้องการ
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="#options" class="btn btn-primary">
              ดูรูปแบบคอร์ส (Private / Group)
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="#enroll" class="btn btn-outline">ปรึกษาฟรี / จองวัดระดับ</a>
          </div>

      

      </div>
    </div>
  </header>

  <!-- LEARNING PROCESS FLOW -->
  <section id="process" class="section bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-animate>
        <h2 class="serif-heading text-4xl text-brand-navy mb-4">ทำไม Intsight แตกต่าง?</h2>
        <p class="text-slate-500 max-w-3xl mx-auto">
          กระบวนการเรียนที่ออกแบบมาเพื่อให้คุณสอบผ่าน GED อย่างมั่นใจ<br>
          ด้วยระบบติดตามและประเมินผลที่เป็นเลิศ
        </p>
      </div>

      <!-- Flow Diagram -->
      <div class="relative" data-animate>
        <!-- Desktop Flow -->
        <div class="hidden lg:block">
          <div class="flex items-center justify-between gap-4 mb-8">
            <!-- Step 1 -->
            <div class="flex-1">
              <div class="surface card-shadow p-6 text-center hover-lift">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">1</div>
                <h3 class="font-bold text-slate-900 mb-2">ประเมินพื้นฐาน</h3>
                <p class="text-sm text-slate-600">วัดระดับความรู้ปัจจุบันด้วย Diagnostic Test</p>
              </div>
            </div>
            <svg class="w-8 h-8 text-brand-navy flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            
            <!-- Step 2 -->
            <div class="flex-1">
              <div class="surface card-shadow p-6 text-center hover-lift">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">2</div>
                <h3 class="font-bold text-slate-900 mb-2">แนะนำแผนเรียน</h3>
                <p class="text-sm text-slate-600">วางแผนจำนวนชั่วโมง และรูปแบบที่เหมาะสม</p>
              </div>
            </div>
            <svg class="w-8 h-8 text-brand-navy flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            
            <!-- Step 3 -->
            <div class="flex-1">
              <div class="surface card-shadow p-6 text-center hover-lift">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">3</div>
                <h3 class="font-bold text-slate-900 mb-2">เรียนและฝึกทำข้อ</h3>
                <p class="text-sm text-slate-600">เรียนตามแผน + ฝึกข้อสอบจริง</p>
              </div>
            </div>
            <svg class="w-8 h-8 text-brand-navy flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            
            <!-- Step 4 -->
            <div class="flex-1">
              <div class="surface card-shadow p-6 text-center hover-lift">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">4</div>
                <h3 class="font-bold text-slate-900 mb-2">สอบเสมือนจริง</h3>
                <p class="text-sm text-slate-600">วัดผลด้วย Mock Test ให้มั่นใจพร้อมสอบ</p>
              </div>
            </div>
          </div>
          
          <div class="flex items-center justify-between gap-4">
            <!-- Step 5 -->
            <div class="flex-1">
              <div class="surface card-shadow p-6 text-center hover-lift">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">5</div>
                <h3 class="font-bold text-slate-900 mb-2">ช่วยสมัครสอบ</h3>
                <p class="text-sm text-slate-600">แนะนำการสมัครสอบ + GED Ready</p>
              </div>
            </div>
            <svg class="w-8 h-8 text-brand-navy flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            
            <!-- Step 6 -->
            <div class="flex-1">
              <div class="surface card-shadow p-6 text-center hover-lift">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">6</div>
                <h3 class="font-bold text-slate-900 mb-2">ติดตามผล</h3>
                <p class="text-sm text-slate-600">ติดตามผลการสอบทุกวิชา</p>
              </div>
            </div>
            <svg class="w-8 h-8 text-brand-navy flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            
            <!-- Step 7 -->
            <div class="flex-1">
              <div class="surface card-shadow p-6 text-center hover-lift bg-gradient-to-br from-[color:var(--gold)] to-yellow-600 text-white">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white text-brand-navy font-bold mb-4">✓</div>
                <h3 class="font-bold mb-2">ได้วุฒิ GED</h3>
                <p class="text-sm opacity-90">สอบผ่านครบและออกใบวุฒิ</p>
              </div>
            </div>
            <div class="w-8 flex-shrink-0"></div>
          </div>
        </div>

        <!-- Mobile Flow -->
        <div class="lg:hidden space-y-6">
          <div class="surface card-shadow p-6">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">1</div>
            <h3 class="font-bold text-slate-900 mb-2">ประเมินพื้นฐาน</h3>
            <p class="text-sm text-slate-600">วัดระดับความรู้ปัจจุบันด้วย Diagnostic Test</p>
          </div>
          
          <div class="flex justify-center">
            <svg class="w-6 h-6 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
          
          <div class="surface card-shadow p-6">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">2</div>
            <h3 class="font-bold text-slate-900 mb-2">แนะนำแผนเรียน</h3>
            <p class="text-sm text-slate-600">วางแผนจำนวนชั่วโมง และรูปแบบที่เหมาะสม</p>
          </div>
          
          <div class="flex justify-center">
            <svg class="w-6 h-6 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
          
          <div class="surface card-shadow p-6">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">3</div>
            <h3 class="font-bold text-slate-900 mb-2">เรียนและฝึกทำข้อ</h3>
            <p class="text-sm text-slate-600">เรียนตามแผน + ฝึกข้อสอบจริง</p>
          </div>
          
          <div class="flex justify-center">
            <svg class="w-6 h-6 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
          
          <div class="surface card-shadow p-6">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">4</div>
            <h3 class="font-bold text-slate-900 mb-2">สอบเสมือนจริง</h3>
            <p class="text-sm text-slate-600">วัดผลด้วย Mock Test ให้มั่นใจพร้อมสอบ</p>
          </div>
          
          <div class="flex justify-center">
            <svg class="w-6 h-6 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
          
          <div class="surface card-shadow p-6">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">5</div>
            <h3 class="font-bold text-slate-900 mb-2">ช่วยสมัครสอบ</h3>
            <p class="text-sm text-slate-600">แนะนำการสมัครสอบ + GED Ready</p>
          </div>
          
          <div class="flex justify-center">
            <svg class="w-6 h-6 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
          
          <div class="surface card-shadow p-6">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-navy text-white font-bold mb-4">6</div>
            <h3 class="font-bold text-slate-900 mb-2">ติดตามผล</h3>
            <p class="text-sm text-slate-600">ติดตามผลการสอบทุกวิชา</p>
          </div>
          
          <div class="flex justify-center">
            <svg class="w-6 h-6 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
          
          <div class="surface card-shadow p-6 bg-gradient-to-br from-[color:var(--gold)] to-yellow-600 text-white">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white text-brand-navy font-bold mb-4">✓</div>
            <h3 class="font-bold mb-2">ได้วุฒิ GED</h3>
            <p class="text-sm opacity-90">สอบผ่านครบและออกใบวุฒิ</p>
          </div>
        </div>
      </div>

      <!-- Why Different -->
      <div class="mt-14 grid md:grid-cols-3 gap-6" data-animate>
        <div class="surface-soft p-6 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-navy text-white text-2xl mb-4">📊</div>
          <h3 class="font-bold text-slate-900 mb-2">ประเมินก่อนเรียน</h3>
          <p class="text-sm text-slate-600">วัดระดับจริง แนะนำชั่วโมงที่เหมาะสม ไม่เสียเวลาและเงินเปล่า</p>
        </div>
        <div class="surface-soft p-6 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-navy text-white text-2xl mb-4">🎯</div>
          <h3 class="font-bold text-slate-900 mb-2">Mock Test เสมือนจริง</h3>
          <p class="text-sm text-slate-600">ทดสอบก่อนสอบจริง วัดความพร้อม ลดความกังวล</p>
        </div>
        <div class="surface-soft p-6 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-navy text-white text-2xl mb-4">🤝</div>
          <h3 class="font-bold text-slate-900 mb-2">ช่วยจนได้วุฒิ</h3>
          <p class="text-sm text-slate-600">ไม่ทิ้งหลังสอบ ติดตามและช่วยดำเนินการออกใบวุฒิ</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COURSE OPTIONS -->
  <section id="options" class="section bg-soft border-y border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-animate>
        <h2 class="serif-heading text-4xl text-brand-navy mb-4">เลือกรูปแบบการเรียน</h2>
        <p class="text-slate-500 max-w-3xl mx-auto">
          เลือกได้ 2 รูปแบบ: Private (ตัวต่อตัว) หรือ Group (เรียนกลุ่ม)
        </p>
      </div>

      <div class="surface card-shadow p-6 lg:p-10" data-animate="zoom-in" x-data="{ opt:'private', p:'60' }">
        <!-- Tab Switch -->
        <div class="flex justify-center gap-4 mb-10">
          <button type="button" 
            class="px-8 py-3 rounded-lg font-bold text-sm transition-all" 
            :class="opt==='private' ? 'bg-brand-navy text-white shadow-lg' : 'bg-white text-slate-600 hover:bg-slate-50'" 
            @click="opt='private'">
            Private (ตัวต่อตัว)
          </button>
          <button type="button" 
            class="px-8 py-3 rounded-lg font-bold text-sm transition-all" 
            :class="opt==='group' ? 'bg-brand-navy text-white shadow-lg' : 'bg-white text-slate-600 hover:bg-slate-50'" 
            @click="opt='group'">
            Group (เรียนกลุ่ม)
          </button>
        </div>

        <!-- Private content -->
        <div class="mt-8" x-show="opt==='private'" x-transition.opacity.duration.200ms>
          <div class="grid lg:grid-cols-12 gap-8 items-start">
            <div class="lg:col-span-5">
              <div class="surface-soft p-6">
                <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">Private 1:1</p>
                <h3 class="text-xl font-bold text-slate-900 mb-2">เลือก 60 หรือ 100 ชั่วโมง</h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                  เลือกแพ็กเกจตามพื้นฐานและกรอบเวลาสอบ (แนะนำวัดระดับก่อนเริ่มเพื่อเลือกได้แม่นยำ)
                </p>

                <div class="mt-5 flex gap-2">
                  <button type="button" class="pill" :class="p==='60' ? 'pill-active' : ''" @click="p='60'">60 hrs</button>
                  <button type="button" class="pill" :class="p==='100' ? 'pill-active' : ''" @click="p='100'">100 hrs</button>
                </div>
              </div>

              <a href="#enroll" class="mt-4 btn btn-primary w-full">ปรึกษาฟรี / จองวัดระดับ</a>
            </div>

            <div class="lg:col-span-7">
              <div class="surface-soft p-6" x-show="p==='60'" x-transition.opacity.duration.200ms>
                <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">Private 60 hrs</p>
                <p class="font-bold text-slate-900 mb-2">เหมาะกับใคร</p>
